{
  "name": "Activity",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "walk",
        "run"
      ],
      "default": "walk"
    },
    "distance_km": {
      "type": "number",
      "default": 0
    },
    "duration_minutes": {
      "type": "number",
      "default": 0
    },
    "calories_burned": {
      "type": "number",
      "default": 0
    },
    "coins_earned": {
      "type": "number",
      "default": 0
    },
    "route_coordinates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "lat": {
            "type": "number"
          },
          "lng": {
            "type": "number"
          }
        }
      }
    },
    "start_time": {
      "type": "string",
      "format": "date-time"
    },
    "end_time": {
      "type": "string",
      "format": "date-time"
    },
    "is_new_route": {
      "type": "boolean",
      "default": true
    },
    "avg_speed_kmh": {
      "type": "number"
    },
    "is_flagged": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "flagged"
      ],
      "default": "completed"
    }
  },
  "required": [
    "type",
    "distance_km"
  ]
}